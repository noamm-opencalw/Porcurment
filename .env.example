# === API Keys (Required) ===

# Gemini API Key (default LLM for deal hunting — fast & cheap)
GEMINI_API_KEY=your_gemini_api_key_here

# Claude OAuth Token (premium & cheap LLMs for analysis)
# Get your token by running: claude auth token
ANTHROPIC_API_KEY=your_claude_oauth_token_here

# Serper.dev API Key (primary web search — 2,500 free queries/month)
# Sign up at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# === Optional ===

# Email SMTP (for sending deal reports — optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Email IMAP (for reading supplier quotes — optional)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# === LLM Models ===
CREWAI_DEFAULT_MODEL=gemini/gemini-2.5-flash
CREWAI_PREMIUM_MODEL=anthropic/claude-sonnet-4-6
CREWAI_CHEAP_MODEL=anthropic/claude-haiku-4-5

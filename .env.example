# Gemini API Key (default LLM)
GEMINI_API_KEY=AIzaSyDCW3Pa05zL6oDAU2vMBz7fxJs6GL4I2bM

# Claude OAuth Token (premium & cheap LLMs)
# Get your token by running: claude auth token
ANTHROPIC_API_KEY=your_claude_oauth_token_here

# Brave Search API
BRAVE_API_KEY=your_brave_api_key_here

# Serper API (fallback search)
SERPER_API_KEY=your_serper_api_key_here

# Email SMTP (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Email IMAP (for reading)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# LLM Models
CREWAI_DEFAULT_MODEL=gemini/gemini-2.5-flash
CREWAI_PREMIUM_MODEL=anthropic/claude-sonnet-4-6
CREWAI_CHEAP_MODEL=anthropic/claude-haiku-4-5
